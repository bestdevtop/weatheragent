{
  "name": "WeatherCoatAgent",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "weather-check",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "weather-check"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\nconst args = body.args || body;\nconst call = body.call || {};\nconst city = args.city || body.city;\n\nlet customerPhone =\n  call.from_number ||\n  call.user_number ||\n  body.from_number ||\n  null;\n\nif (call.direction === 'outbound') {\n  customerPhone = call.to_number || call.user_number || customerPhone;\n}\n\nif (customerPhone) {\n  customerPhone = String(customerPhone).trim();\n  if (!customerPhone.startsWith('+')) {\n    const digits = customerPhone.replace(/\\D/g, '');\n    if (digits) customerPhone = '+' + digits;\n  }\n}\n\nif (!city) {\n  return [{\n    json: {\n      error: true,\n      message: \"I couldn't find a city name. Which town would you like me to check?\"\n    }\n  }];\n}\n\nreturn [{ json: { city: String(city).trim(), customer_phone: customerPhone || null } }];"
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
      "name": "Extract Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
