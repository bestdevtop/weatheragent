    {
      "parameters": {
        "resource": "email",
        "operation": "send",
        "toEmail": "={{ $env.TO_EMAIL }}",
        "subject": "=Coat reminder: {{ $('Get Weather').item.json.name }}",
        "emailFormat": "text",
        "text": "=Today's temperature in {{ $('Get Weather').item.json.name }} is {{ Math.round($('Get Weather').item.json.main.temp) }}°F.\n\nBring a coat.\n\n(SMS fallback — Twilio could not deliver the text message.)",
        "options": {}
      },
      "id": "a1b2c3d4-0008-4000-8000-000000000008",
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [1790, 520],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const weather = $('Get Weather').first().json;\nconst customerPhone = $('Extract Request').first().json.customer_phone;\nconst temp = weather.main.temp;\nconst description = weather.weather[0].description;\nconst cityName = weather.name;\nconst threshold = Number($env.COLD_THRESHOLD_F || 50);\nconst isCold = temp < threshold;\n\nconst smsSent = $('Twilio SMS').isExecuted && !!$('Twilio SMS').first().json.sid;\nconst emailSent = $('Send Email').isExecuted && !!$('Send Email').first().json.messageId;\n\nlet message;\nif (isCold) {\n  if (smsSent) {\n    message = `It's ${Math.round(temp)}°F and ${description} in ${cityName}. It's cold — I've texted you a coat reminder.`;\n  } else if (emailSent) {\n    message = `It's ${Math.round(temp)}°F and ${description} in ${cityName}. It's cold — I've emailed you a coat reminder.`;\n  } else {\n    message = `It's ${Math.round(temp)}°F and ${description} in ${cityName}. It's cold — bring a coat!`;\n  }\n} else {\n  message = `It's ${Math.round(temp)}°F and ${description} in ${cityName}. No coat needed today!`;\n}\n\nreturn [{\n  json: {\n    temperature_f: temp,\n    description,\n    city: cityName,\n    is_cold: isCold,\n    message\n  }\n}];"
      },
      "id": "a1b2c3d4-0009-4000-8000-000000000009",
      "name": "Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1790, 500]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nreturn [{ json: { message: input.message || \"I couldn't find that city. Could you try another name?\" } }];"
      },
