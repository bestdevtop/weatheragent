APP_NAME=Weather Voice Agent API
CORS_ORIGINS=["http://localhost:3000"]

OPENWEATHER_API_KEY=your_openweather_api_key
COLD_THRESHOLD_F=50

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567

TO_EMAIL=your_to_email@example.com

# n8n public URL (required when exposing local n8n to Retell or other external services).
# Without this, n8n shows webhook URLs as http://localhost:5678/... which external callers cannot reach.
# Use your public IP + port, ngrok URL, or domain. Include trailing slash.
# Examples:
#   WEBHOOK_URL=http://203.0.113.50:5678/
#   WEBHOOK_URL=https://abc123.ngrok-free.app/
WEBHOOK_URL=http://YOUR_PUBLIC_IP:5678/
N8N_EDITOR_BASE_URL=http://YOUR_PUBLIC_IP:5678/
